<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP to the VPS server -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">144.91.93.11</domain>
    </domain-config>
    <!-- Allow cleartext for capacitor localhost -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
    <!-- Base config: allow all cleartext for debug APK -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
